# Copy to terraform.tfvars (gitignored) and fill in, OR source via TF_VAR_* env vars.
# Never commit terraform.tfvars containing real credentials.

# atlas_public_key  = "xxxxxxxx"
# atlas_private_key = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

